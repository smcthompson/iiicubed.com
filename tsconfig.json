{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@/*": ["./src/*"]
    },

    "strict": true,

    "jsx": "react-jsx",
    "jsxImportSource": "@kitajs/html",

    "outDir": "./dist",
    "rootDir": "./src",

    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": ["src"]
}
