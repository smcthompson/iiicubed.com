{
  "name": "iiicubed.com",
  "version": "1.0.0",
  "description": "Professional portfolio site highlighting my work.",
  "main": "dist/server.js",
  "scripts": {
    "build": "npm run lint && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "validate": "npm run format:check && npm run lint",
    "dev": "tsx watch src/server.ts --ignore-watch node_modules --ignore-watch dist",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "start:ci": "node dist/server.js",
    "test": "npx playwright test",
    "test:ci": "npm run test",
    "test:grep": "npm run test -- --grep"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smcthompson/iiicubed.com.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#/components": "./dist/components/index.js",
    "#/pages": "./dist/pages/index.js",
    "#/partials": "./dist/partials/index.js",
    "#/routes": "./dist/routes/index.js",
    "#/services": "./dist/services/index.js",
    "#/types": "./dist/types/index.js",
    "#/*": "./dist/*"
  },
  "bugs": {
    "url": "https://github.com/smcthompson/iiicubed.com/issues"
  },
  "homepage": "https://github.com/smcthompson/iiicubed.com#readme",
  "dependencies": {
    "@kitajs/html": "^4.2.13",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.61.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}